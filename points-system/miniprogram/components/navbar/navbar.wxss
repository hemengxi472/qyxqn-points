.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
}
.navbar-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
}
.navbar-left {
  width: 60px;
  display: flex;
  align-items: center;
}
.back-icon {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  padding: 8rpx;
}
.navbar-title {
  flex: 1;
  text-align: center;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
}
.navbar-right {
  width: 60px;
}
