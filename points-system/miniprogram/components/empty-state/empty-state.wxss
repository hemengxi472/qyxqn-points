.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}
.empty-sub {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}
