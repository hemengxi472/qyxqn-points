.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1rpx solid var(--border);
  padding: 20rpx 24rpx;
  z-index: 999;
}
.action-buttons {
  display: flex;
  gap: 20rpx;
}
.btn-approve {
  flex: 2;
  background: var(--success);
  color: #fff;
  border-radius: 44rpx;
  border: none;
  font-size: 30rpx;
}
.btn-reject {
  flex: 1;
  background: #fff;
  color: var(--danger);
  border: 2rpx solid var(--danger);
  border-radius: 44rpx;
  font-size: 30rpx;
}
.btn-cancel {
  background: #f0f0f0;
  border-radius: 44rpx;
  border: none;
  font-size: 28rpx;
}
.btn-reject-confirm {
  background: var(--danger);
  color: #fff;
  border-radius: 44rpx;
  border: none;
  font-size: 28rpx;
}
.comment-box {
  padding-bottom: 16rpx;
}
.comment-input {
  width: 100%;
  height: 120rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}
.comment-actions {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
}
