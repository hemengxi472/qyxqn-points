.preview-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.9);
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.preview-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 40rpx;
  max-height: 80vh;
  overflow-y: auto;
}
.preview-img {
  width: 300rpx;
  height: 300rpx;
  border-radius: 8rpx;
}
.preview-hint {
  color: rgba(255,255,255,0.6);
  font-size: 24rpx;
  margin-top: 20rpx;
}
