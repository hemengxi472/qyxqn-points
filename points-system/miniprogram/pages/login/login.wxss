.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a73e8 0%, #4285f4 50%, #f5f5f5 50%);
}
.login-bg {
  padding: 60rpx 40rpx;
}
.brand {
  text-align: center;
  padding-top: 60rpx;
}
.brand-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}
.brand-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}
.brand-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
  display: block;
}
.login-card {
  margin: 40rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12);
}
.card-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  display: block;
  margin-bottom: 32rpx;
}
.form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.input {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}
.btn-full {
  margin-top: 20rpx;
  width: 100%;
}
.login-loading {
  padding: 100rpx;
  text-align: center;
}
.loading-text {
  font-size: 28rpx;
  color: #fff;
}
