.header-card {
  padding: 8rpx 0 20rpx;
}
.greeting {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
}
.dept {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}
.employee-id {
  font-size: 22rpx;
  color: var(--text-hint);
  background: #f0f0f0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}
.total-card {
  background: linear-gradient(135deg, #1a73e8, #4285f4);
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 32rpx;
  text-align: center;
}
.total-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  display: block;
}
.total-points {
  font-size: 80rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  line-height: 1.3;
}
.total-modules {
  margin-top: 12rpx;
  display: flex;
  justify-content: center;
  gap: 24rpx;
}
.module-dot {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
}
.section-title {
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
}
.log-list {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}
.log-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.log-item:last-child {
  border-bottom: none;
}
.log-left {
  flex: 1;
}
.log-module {
  font-size: 28rpx;
  display: block;
}
.log-date {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}
.log-points {
  font-size: 32rpx;
  font-weight: 600;
}
.log-points.positive {
  color: var(--success);
}
