.status-header {
  text-align: center;
  padding: 32rpx 0;
}
.status-title {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
}
.detail-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.detail-row:last-child {
  border-bottom: none;
}
.d-label {
  width: 140rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}
.d-value {
  flex: 1;
  font-size: 26rpx;
}
.d-value.points {
  color: var(--success);
  font-weight: 600;
}
.photo-section {
  margin-top: 24rpx;
}
.section-label {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
}
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.photo-thumb {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}
