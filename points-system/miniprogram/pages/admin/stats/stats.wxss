.overview-grid {
  display: flex;
  gap: 16rpx;
}
.ov-card {
  flex: 1;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: var(--shadow);
}
.ov-card.highlight {
  background: #fef7e0;
  border: 2rpx solid var(--warning);
}
.ov-number {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
}
.ov-card.highlight .ov-number {
  color: var(--warning);
}
.ov-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
  display: block;
}
.section-title {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  display: block;
}
.module-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}
.bar-label {
  width: 80rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}
.bar-track {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 8rpx;
  min-width: 8rpx;
}
.bar-value {
  font-size: 24rpx;
  color: var(--text-secondary);
  width: 70rpx;
  text-align: right;
}
.rank-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.rank-item:last-child {
  border-bottom: none;
}
.rank-num {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  background: #f0f0f0;
  margin-right: 16rpx;
}
.rank-num.top1 { background: #ffd700; color: #fff; }
.rank-num.top2 { background: #c0c0c0; color: #fff; }
.rank-num.top3 { background: #cd7f32; color: #fff; }
.rank-info {
  flex: 1;
}
.rank-name {
  font-size: 28rpx;
  display: block;
}
.rank-dept {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 2rpx;
}
.rank-points {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}
