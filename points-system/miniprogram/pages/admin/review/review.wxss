.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  gap: 8rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 8rpx;
}
.tab-item.active {
  background: var(--primary);
  color: #fff;
  font-weight: 500;
}
.loading-more {
  text-align: center;
  padding: 24rpx;
  color: var(--text-hint);
}
