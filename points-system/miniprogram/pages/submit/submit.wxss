.info-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.info-row:last-child {
  border-bottom: none;
}
.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}
.info-value {
  font-size: 28rpx;
  font-weight: 500;
}
.info-value.primary {
  color: var(--primary);
}
.info-value.points {
  color: var(--success);
  font-size: 32rpx;
  font-weight: 700;
}
.form-section {
  margin-bottom: 24rpx;
}
.section-label {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}
.section-hint {
  font-size: 24rpx;
  color: var(--text-hint);
  display: block;
  margin-bottom: 16rpx;
}
.desc-input {
  width: 100%;
  height: 160rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
}
