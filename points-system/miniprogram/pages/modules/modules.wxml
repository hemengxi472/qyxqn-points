<view class="container">
  <text class="page-title">选择积分模块</text>
  <text class="page-sub">选择对应的能力模块，提交证明材料获取积分</text>

  <view class="module-grid" wx:if="{{modules.length > 0}}">
    <view class="module-card" wx:for="{{modules}}" wx:key="_id"
          data-id="{{item._id}}" data-name="{{item.name}}" bindtap="onSelectModule">
      <text class="module-icon">{{item.icon}}</text>
      <text class="module-name">{{item.name}}</text>
      <text class="module-desc">{{item.description}}</text>
      <view class="module-footer">
        <text class="module-count">{{item.subcategories.length}} 个子项</text>
        <text class="module-arrow">→</text>
      </view>
    </view>
  </view>

  <empty-state wx:if="{{modules.length === 0 && !loading}}" text="暂无可用模块" />
</view>
