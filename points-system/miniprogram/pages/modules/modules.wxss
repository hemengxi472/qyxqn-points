.page-title {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}
.page-sub {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 24rpx;
}
.module-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.module-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: var(--shadow);
}
.module-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}
.module-name {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}
.module-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 8rpx;
  line-height: 1.5;
}
.module-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}
.module-count {
  font-size: 24rpx;
  color: var(--primary);
}
.module-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
}
