.module-header {
  margin-bottom: 24rpx;
}
.current-module {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
}
.sub-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: block;
}
.sub-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.sub-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: var(--shadow);
}
.sub-left {
  flex: 1;
}
.sub-name {
  font-size: 30rpx;
  font-weight: 500;
  display: block;
}
.sub-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 6rpx;
}
.sub-limit {
  font-size: 22rpx;
  color: var(--warning);
  margin-top: 6rpx;
  display: block;
}
.sub-right {
  text-align: center;
  padding-left: 20rpx;
}
.sub-points {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
  display: block;
}
.sub-unit {
  font-size: 22rpx;
  color: var(--text-hint);
}
.sub-arrow {
  font-size: 28rpx;
  color: var(--text-hint);
  display: block;
  margin-top: 4rpx;
}
